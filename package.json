{
    "name": "smokeshop-growth",
    "version": "1.0.0",
    "description": "Full pipeline: scrape → audit → outreach → email.",
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "start": "node server.js",
        "verify": "node src/node/verify.js",
        "scrape": "node src/node/places_scraper.mjs",
        "scrape:headless": "node src/node/places_scraper.mjs --headless",
        "scrape:batch": "node src/node/batch_scrape.js",
        "scrape:batch:headless": "node src/node/batch_scrape.js --headless",
        "pipeline": "node scripts/run_pipeline.mjs",
        "audit": "node src/node/auditor.mjs",
        "audit:fast": "node src/node/auditor.mjs --concurrency 10 --skip-lighthouse",
        "outreach": "node src/node/generate_outreach.mjs",
        "outreach:preview": "node src/node/generate_outreach.mjs --dry-run",
        "email": "node src/node/send_emails.mjs",
        "email:preview": "node src/node/send_emails.mjs --dry-run",
        "vapi:setup": "node src/node/vapi_agent_setup.mjs",
        "vapi:update": "node src/node/vapi_agent_setup.mjs --update",
        "vapi:dev": "node src/node/start_webhook.js",
        "vapi:webhook": "node src/node/vapi_webhook.js",
        "vapi:call": "node src/node/vapi_call.js",
        "vapi:batch": "node src/node/vapi_call.js --batch",
        "vapi:batch:preview": "node src/node/vapi_call.js --batch --dry-run",
        "retell:call": "node src/node/retell_call.mjs",
        "retell:batch": "node src/node/retell_call.mjs --batch",
        "retell:batch:preview": "node src/node/retell_call.mjs --batch --dry-run",
        "retell:server": "node src/node/retell_custom_llm.mjs",
        "demos": "node src/node/generate-from-templates.mjs",
        "demos:preview": "node src/node/generate-from-templates.mjs --input data/test_leads.csv",
        "test": "node --test tests/*.js",
        "lint": "eslint src/node/ && python -m ruff check src/python/ src/agents/"
    },
    "dependencies": {
        "@playwright/test": "^1.58.2",
        "@sendgrid/mail": "^8.1.6",
        "apify-client": "^2.22.2",
        "axios": "^1.6.8",
        "better-sqlite3": "^12.8.0",
        "cheerio": "^1.0.0-rc.12",
        "chrome-launcher": "^1.1.2",
        "concurrently": "^9.2.1",
        "cors": "^2.8.6",
        "csv-parse": "^6.2.1",
        "csv-parser": "^3.0.0",
        "csv-stringify": "^6.7.0",
        "dotenv": "^17.3.1",
        "elevenlabs": "^1.59.0",
        "express": "^5.2.1",
        "express-rate-limit": "^7.5.1",
        "fast-csv": "^5.0.1",
        "googleapis": "^171.4.0",
        "helmet": "^8.1.0",
        "lighthouse": "^13.0.3",
        "ngrok": "^4.2.2",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.2",
        "openai": "^4.104.0",
        "p-limit": "^3.1.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "puppeteer": "^24.38.0",
        "retell-sdk": "^5.15.0",
        "stripe": "^16.0.0",
        "ws": "^8.20.0"
    }
}
