{
    "name": "google-maps-lead-tools",
    "version": "1.0.0",
    "description": "Full pipeline: scrape → audit → outreach → email.",
    "scripts": {
        "start": "node server.js",
        "verify": "node verify.js",
        "pipeline": "node run_pipeline.js",
        "audit": "node auditor.js",
        "audit:fast": "node auditor.js --concurrency 10 --skip-lighthouse",
        "outreach": "node generate_outreach.js",
        "outreach:preview": "node generate_outreach.js --dry-run",
        "email": "node send_emails.js",
        "email:preview": "node send_emails.js --dry-run",
        "vapi:setup": "node vapi_agent_setup.js",
        "vapi:update": "node vapi_agent_setup.js --update",
        "vapi:dev": "node start_webhook.js",
        "vapi:webhook": "node vapi_webhook.js",
        "vapi:call": "node vapi_call.js",
        "vapi:batch": "node vapi_call.js --batch",
        "vapi:batch:preview": "node vapi_call.js --batch --dry-run"
    },
    "dependencies": {
        "axios": "^1.6.8",
        "cheerio": "^1.0.0-rc.12",
        "chrome-launcher": "^1.1.2",
        "concurrently": "^9.2.1",
        "csv-parser": "^3.0.0",
        "dotenv": "^17.3.1",
        "elevenlabs": "^1.59.0",
        "express": "^5.2.1",
        "express-rate-limit": "^7.5.0",
        "fast-csv": "^5.0.1",
        "googleapis": "^171.4.0",
        "lighthouse": "^12.0.0",
        "ngrok": "^5.0.0-beta.2",
        "nodemailer": "^6.10.1",
        "openai": "^4.104.0",
        "p-limit": "^3.1.0",
        "puppeteer": "^24.38.0"
    }
}