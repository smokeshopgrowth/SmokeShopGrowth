# ─────────────────────────────────────────────────
#  Environment Variables — Lead Generator Dashboard
# ─────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.

# ── Core APIs ────────────────────────────────────

# OpenAI — used for AI content generation (GPT-4o)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs — used for AI voice calling
# Get yours at: https://elevenlabs.io/app/settings/api-keys
ELEVEN_LABS_API_KEY=your_elevenlabs_key_here
ELEVEN_LABS_AGENT_ID=your_agent_id_here

# Minimax — used for demo video generation
# Get yours at: https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# ── Social Media Manager ─────────────────────────

# Buffer — used to schedule posts to Instagram & Facebook
# To get a token:
#   1. Go to https://buffer.com/developers/apps
#   2. Click "Create an App" (for personal use, this is instant)
#   3. Copy the "Access Token" shown in your app settings
BUFFER_ACCESS_TOKEN=your_buffer_access_token_here

# Buffer Profile ID — your connected Instagram or Facebook account in Buffer
# To find yours: run `node src/node/social_scheduler.js --list-profiles`
BUFFER_PROFILE_ID=your_buffer_profile_id_here

# Instagram DM Outreach (social_outreach.js)
# Use a dedicated "outreach" Instagram account — not your personal one
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password
# Path to save/load Instagram session cookies (prevents re-login every run)
IG_SESSION_FILE=.ig-session.json

# ── Google Sheets Export ─────────────────────────
# Spreadsheet ID from the URL after /spreadsheets/d/
GOOGLE_SHEETS_ID=your_google_sheets_id_here
# Path to your Google service account credentials JSON
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# ── Vapi AI Phone Calling ─────────────────────────
# Get yours at: https://dashboard.vapi.ai
VAPI_API_KEY=your_vapi_api_key_here
VAPI_ASSISTANT_ID=your_assistant_id_here
VAPI_PHONE_NUMBER_ID=your_phone_number_id_here
AGENT_NAME=Alex
WEBHOOK_URL=https://your-server.com/vapi/webhook

# ── Stripe Payments ───────────────────────────────
# Get yours at: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
# Webhook signing secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ── CRM / Lead Capture ───────────────────────────
# Optional: external CRM webhook URL (defaults to local /api/lead)
# CRM_WEBHOOK_URL=https://your-crm.com/api/lead
# Google Sheet URL for CRM (used by Python webhook.py)
# GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/your_sheet_id

# ── Demo Site URL ────────────────────────────────
# Where demo sites are served from (Netlify, Vercel, or your server)
DEMO_BASE_URL=https://smoke-shop-premium-demo.netlify.app
# Public URL of your server (for email links, ngrok, etc.)
# PUBLIC_URL=https://your-server.com

# ── Email Follow-Up (SMTP) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=your_email@gmail.com
FROM_NAME=Rory

# ── Server Config ────────────────────────────────
PORT=3000
NODE_ENV=development
FIRECRAWL_API_KEY=fc-57a3c76c67374776a68434bfed161571
