# ── Server ─────────────────────────────────────
PORT=3000
NODE_ENV=production
API_KEY=your_dashboard_api_key_here

# ── Python / Flask ─────────────────────────────
FLASK_DEBUG=false

# ── OpenAI ─────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── SendGrid (Email delivery) ──────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDER_EMAIL=your_email@example.com

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Vapi (AI Voice Calls) ─────────────────────────────────────────────────────
VAPI_API_KEY=your_vapi_api_key_here
VAPI_ASSISTANT_ID=your_assistant_id_here
VAPI_PHONE_NUMBER_ID=your_phone_number_id_here
AGENT_NAME=Alex
WEBHOOK_URL=https://your-server.com/vapi/webhook
# Secret for verifying Vapi webhook requests (set this in Vapi dashboard too)
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here

# ── Stripe Payments ───────────────────────────────
# Get yours at: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
# Webhook signing secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ── CRM / Lead Capture ───────────────────────────
# Optional: external CRM webhook URL (defaults to local /api/lead)
# CRM_WEBHOOK_URL=https://your-crm.com/api/lead
# Google Sheet URL for CRM (used by Python webhook.py)
# GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/your_sheet_id

# ── Demo Site URL ────────────────────────────────
# Where demo sites are served from (Netlify, Vercel, or your server)
DEMO_BASE_URL=https://smoke-shop-premium-demo.netlify.app
# Public URL of your server (for email links, ngrok, etc.)
# PUBLIC_URL=https://your-server.com

# ── Email Follow-Up (SMTP) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=your_email@gmail.com
FROM_NAME=Rory

# ── Server Config ────────────────────────────────
PORT=3000
NODE_ENV=development
API_KEY=your_dashboard_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# Comma-separated origins allowed for CORS (leave empty to allow all in dev)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
