# ── Twilio (SMS follow-ups) ────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_FROM_NUMBER=+1234567890

# ── Email / SMTP ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
FROM_EMAIL=your_email@gmail.com
FROM_NAME=Your Name | Web Design
REPLY_TO=your_email@gmail.com
AGENT_NAME=Alex

# ── SendGrid (legacy) ─────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDER_EMAIL=your_email@example.com

# ── OpenAI ─────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── ElevenLabs ─────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id_here
ELEVENLABS_PHONE_NUMBER_ID=your_elevenlabs_phone_number_id_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# ── Vapi (AI phone calls) ─────────────────────
VAPI_API_KEY=your_vapi_api_key_here
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here

# ── Stripe (payments) ─────────────────────────
STRIPE_API_KEY=your_stripe_api_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── Minimax (demo video generation) ───────────
MINIMAX_API_KEY=your_minimax_api_key_here

# ── Webhooks & Integrations ───────────────────
WEBHOOK_URL=https://your-domain.com/vapi/webhook
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_PORT=3001
ZAPIER_WEBHOOK_URL=your_zapier_webhook_url_here
DEMO_BASE_URL=https://your-demo-domain.com

# ── Google Sheets ──────────────────────────────
GOOGLE_SHEET_URL=your_google_sheet_url_here
SPREADSHEET_ID=your_spreadsheet_id_here

# ── Server ─────────────────────────────────────
PORT=3000
API_KEY=your_dashboard_api_key_here

