# ── Server ─────────────────────────────────────
PORT=3000
NODE_ENV=production
API_KEY=your_dashboard_api_key_here

# ── Python / Flask ─────────────────────────────
FLASK_DEBUG=false

# ── OpenAI ─────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── SendGrid (Email delivery) ──────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDER_EMAIL=your_email@example.com

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Vapi (AI Voice Calls) ─────────────────────────────────────────────────────
# Server-side secret key — NEVER expose this to the browser
VAPI_API_KEY=your_vapi_api_key_here
# Public key — safe to use in the browser / Vapi Web SDK
VAPI_PUBLIC_KEY=your_vapi_public_key_here
# The ID of your Vapi assistant (from the Vapi dashboard)
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
# The ID of the phone number to call from (from the Vapi dashboard)
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here
# Used only by scripts/clone_voice.py migration script — set if you need to copy a voice profile
OLD_VAPI_API_KEY=your_old_vapi_api_key_here
OLD_VAPI_ASSISTANT_ID=your_old_vapi_assistant_id_here

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_API_KEY=your_stripe_api_key_here
# Webhook signing secret from the Stripe dashboard (Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ── Google Sheets CRM ─────────────────────────────────────────────────────────
# Full URL to your Google Sheet (e.g. https://docs.google.com/spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/your_sheet_id_here/edit
# credentials.json (Google Service Account key file) must be placed in the project root
# — do NOT commit credentials.json to git (it's already in .gitignore)

# ── Vercel (Site Deployment) ───────────────────────────────────────────────────
# Personal access token from vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here

# ── MiniMax (Demo Generation) ─────────────────────────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key_here

# ── Demo Site Base URL ────────────────────────────────────────────────────────
# URL of the hosted demo template (used to generate preview links in outreach)
DEMO_BASE_URL=https://smoke-shop-premium-demo.netlify.app
# Public URL of your server (for email links, ngrok, etc.)
# PUBLIC_URL=https://your-server.com

# ── Email Follow-Up (SMTP) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=your_email@gmail.com
FROM_NAME=Rory

# ── Server Config ────────────────────────────────
PORT=3000
NODE_ENV=development
API_KEY=your_dashboard_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# Comma-separated origins allowed for CORS (leave empty to allow all in dev)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
