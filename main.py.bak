
import os
from dotenv import load_dotenv
from playwright.sync_api import sync_playwright
import openai
import re
import http.server
import socketserver
import threading
import random
import unicodedata
import requests
from elevenlabs.client import ElevenLabs

def sanitize_filename(filename):
    """
    Removes invalid characters from a filename.
    """
    filename = unicodedata.normalize('NFKD', filename).encode('ascii', 'ignore').decode('ascii')
    filename = re.sub(r'[^\w\s-]', '', filename).strip().lower()
    filename = re.sub(r'[-\s]+', '-', filename)
    return filename

def send_to_zapier(business_name: str, outcome: str):
    """
    Sends the call outcome to Zapier.
    """
    zapier_webhook_url = os.getenv("ZAPIER_WEBHOOK_URL")
    if zapier_webhook_url:
        data = {"business_name": business_name, "outcome": outcome}
        response = requests.post(zapier_webhook_url, json=data)
        if response.status_code == 200:
            print(f"  Successfully sent outcome to Zapier for {business_name}.")
        else:
            print(f"  Failed to send outcome to Zapier for {business_name}.")
    else:
        print("  Zapier webhook URL not found in .env file.")

def text_to_speech(text: str, filename: str):
    """
    Converts the given text to speech and saves it as an MP3 file.
    """
    client = ElevenLabs(api_key=os.getenv("ELEVENLABS_API_KEY"))
    audio = client.text_to_speech.convert(
        text=text,
        voice_id=os.getenv("ELEVENLABS_VOICE_ID", "cjVigY5qzO86Huf0OWal"),
    )
    with open(filename, "wb") as f:
        for chunk in audio:
            f.write(chunk)

def generate_outreach_message(business_name: str, demo_url: str):
    """
    Generates a personalized outreach message for a given business.
    """
    client = openai.OpenAI()
    response = client.chat.completions.create(
        model="gpt-3.5-turbo",
        messages=[
            {
                "role": "system",
                "content": "You are a helpful assistant that writes friendly outreach messages for a web development agency called SmokeShopGrowth. You will be given a business name and a personalized demo link. Your message should be short, friendly, and encourage the user to check out their personalized demo."
            },
            {
                "role": "user",
                "content": f"Write a short, friendly outreach message to {business_name} and include this personalized demo link: {demo_url}"
            }
        ],
        max_tokens=100,
        n=1,
        stop=None,
        temperature=0.7,
    )
    return response.choices[0].message.content.strip()

def search_google_maps(query: str, limit: int = 10):
    """
    Searches Google Maps for a given query and returns a list of results.
    """
    with sync_playwright() as p:
        browser = p.chromium.launch(headless=False)
        page = browser.new_page()
        page.goto(f"https://www.google.com/maps/search/{query.replace(' ', '+')}")

        # Wait for the results to load
        page.wait_for_timeout(5000)  # Wait 5 seconds for the page to load
        page.wait_for_selector('div[role="article"]', timeout=60000)

        leads = []
        listings = page.locator('div[role="article"]').all()
        for i, listing in enumerate(listings):
            if i >= limit:
                break
            
            # Click on the listing to go to the business page
            listing.click()
            page.wait_for_timeout(5000) # Wait for the page to load

            name_element = page.locator('h1.DUwDvf').all()
            name = name_element[0].inner_text() if name_element else "Not found"

            phone_element = page.locator("button[data-tooltip='Copy phone number']").all()
            phone_number = phone_element[0].get_attribute('aria-label') if phone_element else "Not found"

            if phone_number and phone_number != "Not found":
                # Format the number to E.164
                just_digits = re.sub(r'\D', '', phone_number)
                if len(just_digits) >= 10:
                    phone_number = f"+1{just_digits[-10:]}"
                else:
                    phone_number = "Not found"

            leads.append({"name": name, "phone_number": phone_number})

            # Go back to the search results page
            page.go_back()
            page.wait_for_timeout(5000) # Wait for the page to load

        browser.close()
        return leads

def main():
    """
    Main function to run the Google Maps Lead Scraper.
    """
    load_dotenv()

    # Get API keys from environment variables
    elevenlabs_api_key = os.getenv("ELEVENLABS_API_KEY")
    openai_api_key = os.getenv("OPENAI_API_KEY")
    vapi_api_key = os.getenv("VAPI_API_KEY")
    zapier_webhook_url = os.getenv("ZAPIER_WEBHOOK_URL")
    webhook_url = os.getenv("WEBHOOK_URL", "http://localhost:8000").replace("/vapi", "")

    # Start a web server in a separate thread
    PORT = 8000
    Handler = http.server.SimpleHTTPRequestHandler
    httpd = socketserver.TCPServer(("", PORT), Handler)
    server_thread = threading.Thread(target=httpd.serve_forever)
    server_thread.daemon = True
    server_thread.start()
    print(f"Serving at port {PORT}")


    print("Google Maps Lead Scraper")
    print("========================")
    print()

    # 1. Search Google Maps for leads
    search_queries = ["smoke shops in Houston", "smoke shops in Spring, TX"]
    leads = []
    for search_query in search_queries:
        print(f"Searching for '{search_query}'...")
        leads.extend(search_google_maps(search_query))
    print(f"Found {len(leads)} leads:")
    for lead in leads:
        if lead["name"] != "Not found":
            # Generate a personalized demo link
            demo_url = f"{webhook_url}?shop={lead['name'].replace(' ', '%20')}"
            print(f"- {lead['name']}: {demo_url}")

            message = generate_outreach_message(lead['name'], demo_url)
            print(f"  Outreach message: {message}")

            # Convert the outreach message to speech
            audio_filename = f"{sanitize_filename(lead['name'])}.mp3"
            print(f"  Converting message to speech: {audio_filename}")
            text_to_speech(message, audio_filename)
            print("  Speech conversion complete.")
    print()

    # 4. Convert text to speech with ElevenLabs
    # TODO: Implement ElevenLabs text-to-speech functionality

    # 5. Send call outcomes to Zapier
    # TODO: Implement Zapier webhook functionality

if __name__ == "__main__":
    main()
