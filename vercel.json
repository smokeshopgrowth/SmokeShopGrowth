{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/webhook/(.*)", "dest": "/server.js" },
    { "src": "/demos/(.*)", "dest": "/server.js" },
    { "src": "/social/(.*)", "dest": "/server.js" },
    { "src": "/(.*\\.(html|css|js|png|jpg|ico|svg|json))$", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
